# ─── .env ─────────────────────────────────────────────────────────────────────
# Copy this to .env and fill in your Firebase project values.
# Get these from: Firebase Console → Project Settings → Your Apps → Web
# ─────────────────────────────────────────────────────────────────────────────

VITE_FB_API_KEY=your-api-key
VITE_FB_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FB_PROJECT_ID=your-project-id
VITE_FB_STORAGE_BUCKET=your-project.appspot.com
VITE_FB_MESSAGING_ID=000000000000
VITE_FB_APP_ID=1:000:web:000

# Set to "true" to force emulator connection (auto-detected on localhost)
# VITE_USE_EMULATORS=true
