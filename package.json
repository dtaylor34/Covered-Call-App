{
  "name": "covered-calls-manager",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:emulators": "firebase emulators:start --import=./seed-data --export-on-exit=./seed-data",
    "dev:full": "concurrently \"npm run dev:emulators\" \"npm run dev\"",
    "seed": "node scripts/seed-firestore.js",
    "deploy:functions": "cd functions && npm run deploy",
    "deploy": "firebase deploy"
  },
  "dependencies": {
    "firebase": "^11.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.0.5"
  }
}
