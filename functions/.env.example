# ─── functions/.env ───────────────────────────────────────────────────────────
# Copy this to .env and fill in your values.
# Firebase Functions v2 reads .env files automatically (local/emulator).
#
# For production, use Firebase secrets instead of .env:
#   firebase functions:secrets:set STRIPE_SECRET_KEY
#   firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
#   firebase functions:secrets:set STRIPE_PRICE_ID
#   firebase functions:secrets:set APP_URL
# ─────────────────────────────────────────────────────────────────────────────

# Stripe (required for payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_1T8kwxRFlsXkYLZ30WQrZSEd

# App URL (Stripe redirects; production: https://covered-calls-prod.web.app)
APP_URL=http://localhost:5173

# Market data cache TTLs (seconds, optional)
CACHE_QUOTE_TTL=60
CACHE_CHAIN_TTL=300
CACHE_SCORE_TTL=300
