rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function getUserRole() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data.role : null;
    }
    function isOwner() {
      return getUserRole() == "owner";
    }
    function isAdmin() {
      return getUserRole() in ["owner", "admin"];
    }
    function isTeamMember() {
      return getUserRole() in ["owner", "admin", "moderator"];
    }
    // ── Users ──
    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId || isTeamMember()
      );
      allow create: if request.auth != null && request.auth.uid == userId
                    && !request.resource.data.keys().hasAny(['role']);
      allow update: if request.auth != null && (
        isOwner() ||
        (isAdmin() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) ||
        (request.auth.uid == userId &&
         !request.resource.data.diff(resource.data).affectedKeys()
           .hasAny(['role', 'subscriptionStatus', 'monthlyRate', 'totalPaid']))
      );
      // ── Saved Views ──
      match /savedViews/{viewId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      // ── Saved View Collections ──
      match /savedViewCollections/{collId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      // ── Broker API Connections ──
      // Users can only read/write their own broker connections.
      // Admins can read (for support) but NOT write (never touch user credentials).
      // Note: sensitive fields (appKey, appSecret, accessToken, refreshToken)
      // are written by Cloud Functions, not directly by the client. Firestore
      // rules here enforce ownership; Cloud Functions enforce the logic.
      match /brokerConnections/{brokerId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
      // ── Broker Accounts ──
      // Metadata about accounts linked via the broker OAuth flow.
      // Cloud Functions populate these after token exchange.
      match /brokerAccounts/{accountId} {
        allow read:  if request.auth != null && request.auth.uid == userId;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    // ── Market Data Cache ──
    match /marketData/{docId} {
      allow read: if request.auth != null;
    }
    // ── Audit Log ──
    match /auditLog/{logId} {
      allow read: if request.auth != null && isTeamMember();
      allow create: if request.auth != null && isAdmin();
    }
    // ── Promo Codes ──
    match /promoCodes/{codeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isOwner();
    }
    // ── Analytics Events ──
    match /analyticsEvents/{eventId} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      allow read: if request.auth != null && isTeamMember();
    }
  }
}
